# Copy to .env. Values below are safe local-development defaults only.
APP_ENV=development
APP_SECRET_KEY=change-me-to-a-long-random-value
DATABASE_URL=postgresql+psycopg://techrole:techrole@postgres:5432/techrole
POSTGRES_DB=techrole
POSTGRES_USER=techrole
POSTGRES_PASSWORD=techrole
REDIS_URL=redis://redis:6379/0
CATALOG_CACHE_ENABLED=true
CATALOG_CACHE_TTL_SECONDS=120
FRONTEND_ORIGIN=http://localhost:3000
PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_DATA_MODE=demo
NEXT_PUBLIC_DAGSTER_URL=http://localhost:3001
INTERNAL_API_URL=http://backend:8000
# Generate only for a stable canonical production host; leave empty in local/preview.
INDEXNOW_KEY=
INDEXNOW_ENABLED=false
INDEXNOW_TIMEOUT_SECONDS=20
TELEGRAM_DIGEST_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_TIMEOUT_SECONDS=15
PUBLIC_BUILD_DIR=./frontend/.next-public-live
SITE_ADDRESS=http://localhost
DEMO_MODE=true
DEMO_SEED=20260717
MIN_SALARY_SAMPLE=3

# Payments are disabled until the local sandbox or a provider test shop is selected.
# The example price is test-only and is never trusted from the browser.
PAYMENTS_ENABLED=false
PAYMENTS_PROVIDER=demo
PAYMENTS_MODE=test
PAYMENTS_LIVE_CONFIRMED=false
PAYMENTS_LEGAL_APPROVED=false
# Set true only after a permanent HTTPS domain and always-on hosting are verified.
PAYMENTS_STABLE_HTTPS_CONFIRMED=false
PAYMENTS_TERMS_VERSION=draft-2026-07-21
PAYMENTS_SELLER_STATUS=unconfirmed
PAYMENTS_FISCALIZATION_MODE=disabled
PREMIUM_30_DAYS_PRICE_RUB=290.00

# Реквизиты владельца для опубликованных юридических страниц. Заполните только в локальном/production .env.
SELLER_NAME=
SELLER_INN=
SELLER_PHONE=
SELLER_ADDRESS=
SELLER_EMAIL=sqldevelopermoscow@yandex.com
LEGAL_EFFECTIVE_DATE=2026-07-22

# Create a YooKassa test shop yourself and store its credentials only in .env.
# Do not put production keys in this example or in Git.
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_API_URL=https://api.yookassa.ru/v3
YOOKASSA_TIMEOUT_SECONDS=15
# 0 means "not legally selected". Set 1..12 only after confirming the tax rate.
YOOKASSA_VAT_CODE=0

# Robokassa test/live credentials are created in the owner's merchant account.
# Password #3 is used only for live refund API calls. Keep every password in .env.
ROBOKASSA_MERCHANT_LOGIN=
ROBOKASSA_PASSWORD1=
ROBOKASSA_PASSWORD2=
ROBOKASSA_PASSWORD3=
# Must exactly match the hash algorithm selected in Robokassa technical settings.
ROBOKASSA_HASH_ALGORITHM=sha256
ROBOKASSA_PAYMENT_URL=https://auth.robokassa.ru/Merchant/Index.aspx
ROBOKASSA_OP_STATE_URL=https://auth.robokassa.ru/Merchant/WebService/Service.asmx/OpStateExt
ROBOKASSA_REFUND_URL=https://services.robokassa.ru/RefundService/Refund/Create
ROBOKASSA_REFUND_STATE_URL=https://services.robokassa.ru/RefundService/Refund/GetState
ROBOKASSA_TIMEOUT_SECONDS=15
CBR_CURRENCY_ENABLED=false
CBR_CURRENCY_BASE_URL=https://www.cbr.ru/scripts/XML_daily.asp
CBR_CURRENCY_TIMEOUT_SECONDS=15

# Read-only nightly verification of dated public Habr Career salary metadata.
SALARY_SOURCE_AUDIT_ENABLED=false
SALARY_SOURCE_AUDIT_TIMEOUT_SECONDS=15

# Demo users are seeded only when DEMO_MODE=true. Change these locally.
DEMO_FREE_PASSWORD=FreeDemo-ChangeMe1!
DEMO_PREMIUM_PASSWORD=PremiumDemo-ChangeMe1!
DEMO_ADMIN_PASSWORD=AdminDemo-ChangeMe1!

# Official HH API integration is disabled unless every guard below is satisfied.
HH_ENABLED=false
HH_COMMERCIAL_USE_CONFIRMED=false
HH_CONTACT_EMAIL=
HH_APP_NAME=TechRoleIndex
HH_ACCESS_TOKEN=

# Optional AI assistant. Never required for ingestion or classification.
AI_CLASSIFIER_ENABLED=false
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=
AI_CLASSIFIER_TIMEOUT_SECONDS=300
AI_CLASSIFIER_MAX_PER_RUN=3

# Official open-data API of the Russian public employment portal.
TRUDVSEM_ENABLED=false
TRUDVSEM_BASE_URL=https://opendata.trudvsem.ru/api/v1
TRUDVSEM_TERMS_URL=https://trudvsem.ru/opendata/api
TRUDVSEM_QUERY_LIMIT=100
TRUDVSEM_MAX_PROFESSIONS=50
TRUDVSEM_HISTORY_DAYS=180
TRUDVSEM_MAX_PAGES_PER_QUERY=100
TRUDVSEM_USE_ALIAS_QUERIES=true
TRUDVSEM_REQUEST_DELAY_SECONDS=0.25

# On-site support. Keep SMTP disabled until a Yandex app password is stored
# only in the local .env file (never commit it).
SUPPORT_EMAIL_ENABLED=false
NIGHTLY_REPORT_EMAIL_ENABLED=false
SUPPORT_RECIPIENT_EMAIL=sqldevelopermoscow@yandex.com
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USERNAME=sqldevelopermoscow
SMTP_PASSWORD=
SMTP_FROM_EMAIL=sqldevelopermoscow@yandex.com
SMTP_USE_SSL=true
SMTP_TIMEOUT_SECONDS=15
