{
  "name": "techrole-index-frontend",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.14.0",
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0",
    "build": "next build",
    "prepare:standalone": "node scripts/prepare-standalone.mjs",
    "build:standalone": "npm run build && npm run prepare:standalone",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit --project tsconfig.check.json",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "audit:public": "node scripts/audit-public.mjs"
  },
  "dependencies": {
    "echarts": "6.1.0",
    "lucide-react": "^0.468.0",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.0",
    "eslint-config-next": "16.2.10",
    "jsdom": "^26.0.0",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
