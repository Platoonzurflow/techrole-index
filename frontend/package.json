{
  "name": "techrole-index-frontend",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.14.0",
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0",
    "build": "next build",
    "prepare:standalone": "node scripts/prepare-standalone.mjs",
    "build:standalone": "npm run build && npm run prepare:standalone",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit --project tsconfig.check.json",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "audit:public": "node scripts/audit-public.mjs"
  },
  "dependencies": {
    "echarts": "6.1.0",
    "lucide-react": "^1.25.0",
    "next": "16.2.11",
    "react": "19.2.8",
    "react-dom": "19.2.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.1",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^26.1.1",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "autoprefixer": "^10.5.4",
    "eslint": "^10.7.0",
    "eslint-config-next": "16.2.11",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.21",
    "tailwindcss": "^4.3.3",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
